---
import AdminLayout from "../../components/admin/AdminLayout.astro";
import PreviewFrame from "../../components/admin/PreviewFrame.astro";
import { readManifest } from "../../lib/admin/manifest";
import "../../styles/admin/gallery-editor.css";

const m = await readManifest();
const visible = m.images
  .filter((i) => i.usedIn.gallery && !i.hidden)
  .sort((a, b) => a.galleryOrder - b.galleryOrder);
const hidden = m.images
  .filter((i) => i.hidden)
  .sort((a, b) => a.filename.localeCompare(b.filename));
const unused = m.images
  .filter((i) => !i.usedIn.gallery && !i.hidden && i.usedIn.pressOnPackages.length === 0)
  .sort((a, b) => a.filename.localeCompare(b.filename));
const usedElsewhere = m.images
  .filter((i) => !i.usedIn.gallery && !i.hidden && (i.usedIn.carousel || i.usedIn.pressOnPackages.length > 0))
  .sort((a, b) => a.filename.localeCompare(b.filename));
---
<AdminLayout title="Gallery" active="gallery">
  <div slot="topbar-right" class="ce-topbar">
    <button class="btn" id="ce-save">💾 Guardar</button>
    <span class="ce-saved-indicator" id="ce-saved-indicator" hidden>✓ Guardado</span>
    <button class="btn" id="ce-preview-toggle">👁 Preview</button>
  </div>

  <p class="ce-hint">Arrastra imágenes a <strong>Visibles</strong> para incluirlas en la galería pública. El orden es el que verá el visitante. Las imágenes ocultas no se renderizan en ningún lado.</p>

  <div class="ce-layout">
    <div class="ce-pane">
      <div class="ce-pane-header">
        <h3>Visibles <span class="ce-pane-count" id="ce-visible-count">{visible.length}</span></h3>
      </div>
      <div class="ce-list" id="ce-visible-list" data-zone="visible">
        {visible.map((img) => (
          <div class="ce-card" data-id={img.id}>
            <div class="ce-card-handle">⋮⋮</div>
            <img src={`/optimized/${img.id}/400.webp`} alt={img.alt} loading="lazy" />
            <div class="ce-card-info">
              <div class="ce-card-name">{img.filename}</div>
              <div class="ce-card-alt">{img.alt}</div>
            </div>
            <button class="ce-card-remove" data-action="remove" title="Quitar de la galería">×</button>
          </div>
        ))}
        {visible.length === 0 && (
          <div class="ce-empty">Arrastra imágenes aquí</div>
        )}
      </div>
    </div>

    <div class="ce-pane">
      <div class="ce-pane-header">
        <h3>Disponibles <span class="ce-pane-count">{unused.length + usedElsewhere.length + hidden.length}</span></h3>
        <input type="search" class="ce-filter" id="ce-filter" placeholder="Filtrar…" />
      </div>
      <div class="ce-list ce-list-available" id="ce-available-list" data-zone="available">
        {usedElsewhere.length > 0 && <div class="ce-subhead">En otros lugares</div>}
        {usedElsewhere.map((img) => (
          <div class="ce-card ce-card-available" data-id={img.id}>
            <div class="ce-card-handle">⋮⋮</div>
            <img src={`/optimized/${img.id}/400.webp`} alt={img.alt} loading="lazy" />
            <div class="ce-card-info">
              <div class="ce-card-name">{img.filename}</div>
              <div class="ce-card-alt">
                {img.usedIn.carousel && <span class="ce-mini-badge">Carousel</span>}
                {img.usedIn.pressOnPackages.length > 0 && <span class="ce-mini-badge">Press-On</span>}
              </div>
            </div>
            <button class="ce-card-add" data-action="add" title="Añadir a la galería">+</button>
          </div>
        ))}
        {unused.length > 0 && <div class="ce-subhead">Sin usar</div>}
        {unused.map((img) => (
          <div class="ce-card ce-card-available" data-id={img.id}>
            <div class="ce-card-handle">⋮⋮</div>
            <img src={`/optimized/${img.id}/400.webp`} alt={img.alt} loading="lazy" />
            <div class="ce-card-info">
              <div class="ce-card-name">{img.filename}</div>
              <div class="ce-card-alt">{img.alt}</div>
            </div>
            <button class="ce-card-add" data-action="add" title="Añadir a la galería">+</button>
          </div>
        ))}
        {hidden.length > 0 && <div class="ce-subhead">Ocultas</div>}
        {hidden.map((img) => (
          <div class="ce-card ce-card-available ce-card-dim" data-id={img.id}>
            <div class="ce-card-handle">⋮⋮</div>
            <img src={`/optimized/${img.id}/400.webp`} alt={img.alt} loading="lazy" />
            <div class="ce-card-info">
              <div class="ce-card-name">{img.filename}</div>
              <div class="ce-card-alt">oculta</div>
            </div>
          </div>
        ))}
        {(unused.length + usedElsewhere.length + hidden.length) === 0 && (
          <div class="ce-empty">Sin imágenes. Sube más en Image Library.</div>
        )}
      </div>
    </div>

    <PreviewFrame src="/gallery" label="Preview de la galería" />
  </div>

  <script>
    // @ts-nocheck
    import Sortable from 'sortablejs';

    const visibleList = document.getElementById('ce-visible-list');
    const availableList = document.getElementById('ce-available-list');
    const saveBtn = document.getElementById('ce-save');
    const savedIndicator = document.getElementById('ce-saved-indicator');
    const previewToggle = document.getElementById('ce-preview-toggle');
    const previewFrame = document.getElementById('admin-preview-frame');
    const visibleCount = document.getElementById('ce-visible-count');
    const filterInput = document.getElementById('ce-filter');

    let dirty = false;

    function markDirty() {
      dirty = true;
      savedIndicator.hidden = true;
      saveBtn.classList.add('btn-primary');
    }

    function markClean() {
      dirty = false;
      savedIndicator.hidden = false;
      saveBtn.classList.remove('btn-primary');
    }

    new Sortable(visibleList, {
      group: 'gallery',
      animation: 150,
      handle: '.ce-card-handle',
      ghostClass: 'ce-card-ghost',
      onUpdate: markDirty,
      onAdd: markDirty,
      onRemove: markDirty,
    });

    new Sortable(availableList, {
      group: 'gallery',
      animation: 150,
      handle: '.ce-card-handle',
      ghostClass: 'ce-card-ghost',
      filter: '.ce-card-add',
      preventOnFilter: false,
      onAdd: (e) => {
        const card = e.item;
        const btn = card.querySelector('[data-action="add"]');
        if (btn) {
          btn.dataset.action = 'remove';
          btn.textContent = '×';
          btn.title = 'Quitar de la galería';
          btn.classList.remove('ce-card-add');
          btn.classList.add('ce-card-remove');
        }
        markDirty();
      },
    });

    function refresh() {
      visibleCount.textContent = String(visibleList.querySelectorAll('.ce-card').length);
    }

    visibleList.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action="remove"]');
      if (!btn) return;
      const card = btn.closest('.ce-card');
      availableList.appendChild(card);
      btn.remove();
      markDirty();
      refresh();
    });

    availableList.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action="add"]');
      if (!btn) return;
      const card = btn.closest('.ce-card');
      visibleList.appendChild(card);
      btn.dataset.action = 'remove';
      btn.textContent = '×';
      btn.title = 'Quitar de la galería';
      btn.classList.remove('ce-card-add');
      btn.classList.add('ce-card-remove');
      markDirty();
      refresh();
    });

    filterInput.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      availableList.querySelectorAll('.ce-card').forEach((c) => {
        c.style.display = c.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });

    saveBtn.addEventListener('click', async () => {
      const visible = [...visibleList.querySelectorAll('.ce-card')].map((c) => c.dataset.id);
      const r = await fetch('/api/admin/gallery', {
        method: 'PUT',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ visible }),
      });
      if (r.ok) {
        markClean();
        window.adminToast(`Guardado · ${visible.length} visible(s)`, 'success');
        const iframe = document.getElementById('admin-preview-iframe');
        if (iframe && !previewFrame.hidden) {
          iframe.src = iframe.src.split('?')[0] + '?t=' + Date.now();
        }
      } else {
        window.adminToast('Error al guardar', 'error');
      }
    });

    previewToggle.addEventListener('click', () => {
      const visible = previewFrame.hidden;
      previewFrame.hidden = visible;
      previewToggle.textContent = visible ? '✕ Cerrar preview' : '👁 Preview';
    });

    window.addEventListener('beforeunload', (e) => {
      if (dirty) { e.preventDefault(); e.returnValue = ''; }
    });

    refresh();
  </script>
</AdminLayout>
