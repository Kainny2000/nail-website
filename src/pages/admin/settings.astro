---
import AdminLayout from "../../components/admin/AdminLayout.astro";
import { readManifest } from "../../lib/admin/manifest";
import "../../styles/admin/settings.css";

const m = await readManifest();
const opt = m.optimization;
---
<AdminLayout title="Settings" active="settings">
  <div class="settings-section">
    <h2 class="settings-section-title">Optimización de imágenes</h2>
    <p class="settings-hint">Las imágenes se generan en los formatos y anchos elegidos al subirlas. Si cambias estos valores, regenera las variantes para que apliquen a las imágenes existentes.</p>

    <div class="settings-grid">
      {(['carousel', 'gallery', 'pressOn'] as const).map((key) => (
        <div class="settings-card" data-section={key}>
          <h3 class="settings-card-title">
            {key === 'carousel' && 'Carrusel (home)'}
            {key === 'gallery' && 'Galería'}
            {key === 'pressOn' && 'Press-On'}
          </h3>

          <label class="settings-field">
            <span>Anchos (px, separados por coma)</span>
            <input type="text" data-field="widths" value={opt[key].widths.join(', ')} />
          </label>

          <div class="settings-field">
            <span>Formatos (en orden de preferencia)</span>
            <div class="settings-formats" data-field="formats">
              {(['avif', 'webp', 'jpeg'] as const).map((f) => (
                <label class="settings-format-chip">
                  <input type="checkbox" data-format={f} checked={opt[key].formats.includes(f)} />
                  <span>{f.toUpperCase()}</span>
                </label>
              ))}
            </div>
          </div>

          <label class="settings-field">
            <span>Calidad: <strong data-quality-display>{opt[key].quality}</strong></span>
            <input type="range" data-field="quality" min="40" max="95" value={opt[key].quality} />
          </label>

          <div class="settings-field">
            <span>Ajuste</span>
            <div class="settings-fit">
              <label>
                <input type="radio" name="fit-{key}" data-fit="cover" checked={opt[key].fit === 'cover'} />
                Cover
              </label>
              <label>
                <input type="radio" name="fit-{key}" data-fit="contain" checked={opt[key].fit === 'contain'} />
                Contain
              </label>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="settings-actions">
      <button class="btn btn-primary" id="settings-save">💾 Guardar perfiles</button>
      <button class="btn" id="settings-regenerate">↻ Regenerar todas las variantes</button>
      <span class="settings-status" id="settings-status"></span>
    </div>
  </div>

  <div class="settings-section">
    <h2 class="settings-section-title">Sesión</h2>
    <p class="settings-hint">Para cambiar la contraseña edita el archivo <code>.env</code> y reinicia el servidor.</p>
    <code class="settings-code">ADMIN_PASSWORD=tu-nueva-clave</code>
  </div>

  <div class="settings-section">
    <h2 class="settings-section-title">Estadísticas del manifest</h2>
    <ul class="settings-stats">
      <li><strong>{m.images.length}</strong> imágenes totales</li>
      <li><strong>{m.images.filter((i) => i.usedIn.carousel).length}</strong> en carousel</li>
      <li><strong>{m.images.filter((i) => i.usedIn.gallery).length}</strong> en galería</li>
      <li><strong>{m.images.filter((i) => i.usedIn.pressOnPackages.length > 0).length}</strong> en press-on</li>
      <li><strong>{m.images.filter((i) => i.hidden).length}</strong> ocultas</li>
      <li><strong>{m.pressOnPackages.length}</strong> paquetes press-on</li>
      <li class="settings-stats-meta">Última actualización: <code>{new Date(m.updatedAt).toLocaleString()}</code></li>
    </ul>
  </div>

  <script>
    // @ts-nocheck
    function readCard(card) {
      const widthsRaw = card.querySelector('[data-field="widths"]').value;
      const widths = widthsRaw.split(/[,\s]+/).map(s => parseInt(s)).filter(n => !isNaN(n) && n > 0);
      const formats = [...card.querySelectorAll('[data-format]:checked')].map(cb => cb.dataset.format);
      const quality = parseInt(card.querySelector('[data-field="quality"]').value);
      const fit = card.querySelector('[data-fit]:checked')?.dataset.fit || 'cover';
      return { widths, formats, quality, fit };
    }

    document.querySelectorAll('.settings-card').forEach(card => {
      const slider = card.querySelector('[data-field="quality"]');
      const display = card.querySelector('[data-quality-display]');
      slider.addEventListener('input', () => { display.textContent = slider.value; });
    });

    document.getElementById('settings-save').addEventListener('click', async () => {
      const body = {};
      for (const card of document.querySelectorAll('.settings-card')) {
        body[card.dataset.section] = readCard(card);
      }
      const r = await fetch('/api/admin/optimization', {
        method: 'PUT',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (r.ok) {
        window.adminToast('Perfiles guardados', 'success');
      } else {
        window.adminToast('Error al guardar', 'error');
      }
    });

    document.getElementById('settings-regenerate').addEventListener('click', async () => {
      if (!confirm('¿Regenerar TODAS las variantes? Esto puede tardar varios segundos.')) return;
      const status = document.getElementById('settings-status');
      status.textContent = 'Regenerando…';
      const t0 = Date.now();
      const r = await fetch('/api/admin/optimization', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({}),
      });
      if (r.ok) {
        const data = await r.json();
        status.textContent = `✓ ${data.processed} imágenes regeneradas en ${((Date.now() - t0) / 1000).toFixed(1)}s`;
        window.adminToast(`${data.processed} imágenes regeneradas`, 'success');
      } else {
        status.textContent = 'Error';
        window.adminToast('Error al regenerar', 'error');
      }
    });
  </script>
</AdminLayout>
