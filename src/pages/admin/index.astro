---
import "../../styles/admin.css";
import { verifyCredentials, totpStatus, totpSecret, totpEnroll, newTotpSecret, verifyTotpCode, otpauthUri } from "../../server/lib/auth";
import { readPreAuth } from "../../server/lib/session";
import { getEnv } from "../../server/lib/env";
import QRCode from "qrcode";

const env = getEnv();
const cookieHeader = Astro.request.headers.get("cookie") ?? "";

let state: "login" | "totp" | "setup" | "dashboard" = "login";
let loginError = "";
let totpQr = "";
let totpSetupSecret = "";

if (Astro.locals.session && Astro.locals.session.uid === "admin") {
  state = "dashboard";
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action")?.toString();

  if (action === "login") {
    const username = form.get("username")?.toString() ?? "";
    const password = form.get("password")?.toString() ?? "";
    const user = await verifyCredentials(username, password);
    if (!user) {
      loginError = "Invalid credentials";
      state = "login";
    } else {
      const enrolled = await totpStatus();
      if (enrolled) {
        const payload = JSON.stringify({ uid: user.uid, login: user.login, iat: Date.now() });
        const encoded = Buffer.from(payload).toString("base64url");
        const { hmacSign } = await import("../../server/lib/crypto");
        const sig = hmacSign(encoded, env.SESSION_SECRET);
        Astro.cookies.set("__nail_pre", `${encoded}.${sig}`, {
          path: "/", httpOnly: true, secure: true, sameSite: "lax", maxAge: 5 * 60,
        });
        state = "totp";
      } else {
        const secret = newTotpSecret();
        totpSetupSecret = secret;
        try { totpQr = await QRCode.toDataURL(otpauthUri(secret, username)); } catch { totpQr = ""; }
        state = "setup";
      }
    }
  } else if (action === "totp-verify") {
    const token = form.get("token")?.toString() ?? "";
    const pre = readPreAuth(cookieHeader);
    if (!pre) {
      state = "login";
    } else {
      const secret = await totpSecret();
      if (secret && verifyTotpCode(secret, token)) {
        const payload = JSON.stringify({ uid: pre.uid, login: pre.login, totpVerified: true, iat: Date.now(), nonce: Math.random().toString(36).slice(2) });
        const encoded = Buffer.from(payload).toString("base64url");
        const { hmacSign, randomToken } = await import("../../server/lib/crypto");
        const sig = hmacSign(encoded, env.SESSION_SECRET);
        Astro.cookies.set("__nail_session", `${encoded}.${sig}`, { path: "/", httpOnly: true, secure: true, sameSite: "lax", maxAge: 60 * 60 });
        Astro.cookies.set("__nail_csrf", randomToken(24), { path: "/", httpOnly: false, secure: true, sameSite: "lax", maxAge: 60 * 60 });
        state = "dashboard";
      } else {
        loginError = "Invalid TOTP code";
        state = "totp";
      }
    }
  } else if (action === "totp-setup") {
    const token = form.get("token")?.toString() ?? "";
    const secret = form.get("secret")?.toString() ?? "";
    if (!secret || !verifyTotpCode(secret, token)) {
      loginError = "Invalid TOTP setup code.";
      totpSetupSecret = secret;
      try { totpQr = await QRCode.toDataURL(otpauthUri(secret, "admin")); } catch { totpQr = ""; }
      state = "setup";
    } else {
      await totpEnroll(secret);
      const payload = JSON.stringify({ uid: "admin", login: "admin", totpVerified: true, iat: Date.now(), nonce: Math.random().toString(36).slice(2) });
      const encoded = Buffer.from(payload).toString("base64url");
      const { hmacSign, randomToken } = await import("../../server/lib/crypto");
      const sig = hmacSign(encoded, env.SESSION_SECRET);
      Astro.cookies.set("__nail_session", `${encoded}.${sig}`, { path: "/", httpOnly: true, secure: true, sameSite: "lax", maxAge: 60 * 60 });
      Astro.cookies.set("__nail_csrf", randomToken(24), { path: "/", httpOnly: false, secure: true, sameSite: "lax", maxAge: 60 * 60 });
      state = "dashboard";
    }
  }
}

if (state === "dashboard") {
  let csrf = Astro.cookies.get("__nail_csrf")?.value;
  if (!csrf) {
    const crypto = await import("node:crypto");
    csrf = crypto.randomBytes(32).toString("hex");
    Astro.cookies.set("__nail_csrf", csrf, { path: "/", httpOnly: false, secure: true, sameSite: "lax", maxAge: 60 * 60 });
  }
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin | Coco Nails</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="admin-body">

{state === "login" && (
<div class="admin-shell">
  <div class="card auth-card">
    <h2 class="card-header">Admin Login</h2>
    <form method="POST">
      <div class="form-group">
        <label for="username">Username</label>
        <input id="username" name="username" class="form-input" required autofocus autocomplete="username" />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" class="form-input" required autocomplete="current-password" />
      </div>
      <input type="hidden" name="_action" value="login" />
      <button type="submit" class="btn btn-primary" style="width:100%;margin-top:12px">Sign In</button>
    </form>
    {loginError && <div class="login-error">{loginError}</div>}
  </div>
</div>
)}

{state === "totp" && (
<div class="admin-shell">
  <div class="card auth-card">
    <h2 class="card-header">Verification Code</h2>
    <form method="POST">
      <div class="form-group">
        <label for="token">6-digit code from authenticator</label>
        <input id="token" name="token" class="form-input" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" required autofocus />
      </div>
      <input type="hidden" name="_action" value="totp-verify" />
      <button type="submit" class="btn btn-primary" style="width:100%;margin-top:12px">Verify</button>
    </form>
    {loginError && <div class="login-error">{loginError}</div>}
  </div>
</div>
)}

{state === "setup" && (
<div class="admin-shell">
  <div class="card auth-card">
    <h2 class="card-header">Set Up 2FA</h2>
    {totpQr && (
    <div style="text-align:center;margin-bottom:16px">
      <img src={totpQr} alt="TOTP QR Code" width="200" height="200" />
      <p style="font-size:0.8rem;color:var(--admin-muted);margin-top:8px">Scan with your authenticator app</p>
    </div>
    )}
    <form method="POST">
      <input type="hidden" name="secret" value={totpSetupSecret} />
      <div class="form-group">
        <label for="token">Enter the 6-digit code to confirm</label>
        <input id="token" name="token" class="form-input" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" required autofocus />
      </div>
      <input type="hidden" name="_action" value="totp-setup" />
      <button type="submit" class="btn btn-primary" style="width:100%;margin-top:12px">Confirm</button>
    </form>
    {loginError && <div class="login-error">{loginError}</div>}
  </div>
</div>
)}

{state === "dashboard" && (
<div class="admin-shell">
  <div class="admin-header">
    <h1>Coco Nails Admin</h1>
    <form method="POST" action="/api/auth/logout" style="margin:0">
      <button type="submit" class="btn-logout">Logout</button>
    </form>
  </div>

  <div class="admin-tabs">
    <button class="admin-tab active" data-tab="tab-upload">Upload Images</button>
    <button class="admin-tab" data-tab="tab-manager">Image Manager</button>
    <button class="admin-tab" data-tab="tab-presson">Press-On Cards</button>
  </div>

  <div class="tab-content active" id="tab-upload">
    <div class="card">
      <h3 class="card-header">Upload Images</h3>
      <div class="form-group">
        <label>Assign to sections</label>
        <div class="section-checkboxes">
          <label class="section-checkbox"><input type="checkbox" name="upload-sections" value="slideshow" checked /> Slideshow</label>
          <label class="section-checkbox"><input type="checkbox" name="upload-sections" value="gallery" checked /> Gallery</label>
          <label class="section-checkbox"><input type="checkbox" name="upload-sections" value="presson" checked /> Press-on</label>
        </div>
      </div>
      <div class="form-group">
        <label for="upload-alt">Alt text (applied to all files)</label>
        <input id="upload-alt" class="form-input" placeholder="e.g. Pink almond nails" maxlength="200" />
      </div>
      <div class="upload-zone" id="upload-zone">
        <span class="upload-zone-icon">+</span>
        <p class="upload-zone-text">Drop images here or click to browse</p>
        <p class="upload-zone-hint">JPEG, PNG, WebP, HEIC (iPhone) — max 8MB each</p>
        <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/heic,image/heif,.heic,.heif" multiple hidden />
      </div>
      <div class="upload-preview-list" id="preview-list"></div>
      <div class="progress-bar" id="progress-bar" style="display:none"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
      <div class="upload-errors" id="upload-errors"></div>
      <div style="margin-top:20px">
        <button class="btn btn-primary" id="btn-upload" disabled>Upload</button>
        <button class="btn btn-secondary" id="btn-clear-upload" style="margin-left:8px;display:none">Clear</button>
      </div>
    </div>
  </div>

  <div class="tab-content" id="tab-manager">
    <div class="card">
      <div class="batch-toolbar">
        <h3 class="card-header" style="margin:0">Image Manager</h3>
        <div class="batch-actions" id="batch-actions">
          <span class="batch-count" id="batch-count"></span>
          <button class="btn btn-secondary btn-sm" id="btn-batch-sections">Set Sections</button>
          <button class="btn btn-danger btn-sm" id="btn-batch-delete">Delete Selected</button>
        </div>
      </div>
      <div class="image-grid" id="image-grid"><div class="empty-state">Loading...</div></div>
    </div>
  </div>

  <div class="tab-content" id="tab-presson">
    <div class="card">
      <h3 class="card-header" id="po-form-header">Create New Card</h3>
      <form id="presson-create-form">
        <input type="hidden" id="po-edit-id" value="" />
        <div class="form-inline">
          <div class="form-group"><label for="po-name">Card Name</label><input id="po-name" class="form-input" required maxlength="100" placeholder="e.g. Glitter Set" /></div>
          <div class="form-group"><label for="po-price">Price</label><input id="po-price" class="form-input" maxlength="50" placeholder="$25.00" /></div>
          <div class="form-group"><label for="po-description">Description</label><input id="po-description" class="form-input" maxlength="500" placeholder="Short description" /></div>
          <div class="form-group" style="align-self:flex-end">
            <button type="submit" class="btn btn-primary" id="po-submit-btn">Add Card</button>
            <button type="button" class="btn btn-secondary" id="btn-cancel-edit" style="display:none;margin-left:8px">Cancel</button>
          </div>
        </div>
        <div class="form-group" style="margin-top:12px">
          <label>Card Image (select from uploaded)</label>
          <div class="image-picker" id="po-image-picker"></div>
          <input type="hidden" id="po-imageId" value="" />
        </div>
      </form>
    </div>
    <div class="card">
      <h3 class="card-header">Active Cards</h3>
      <div class="presson-list" id="presson-list"><div class="empty-state">Loading...</div></div>
    </div>
  </div>
</div>
)}

<div class="toast-container" id="toast-container"></div>
<script is:inline src="/admin.js"></script>

  </body>
</html>