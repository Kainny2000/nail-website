---
import "../../styles/admin/login.css";
const url = new URL(Astro.request.url);
const next = url.searchParams.get("next") ?? "/admin";
const error = url.searchParams.get("error");
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin · Bare Form</title>
  </head>
  <body class="login-body">
    <main class="login-card">
      <div class="login-brand">
        <div class="login-mark">BF</div>
        <h1 class="login-title">Bare Form Admin</h1>
        <p class="login-sub">Inicia sesión para gestionar el sitio</p>
      </div>

      {error && <div class="login-error">{error}</div>}

      <form method="POST" action="/api/admin/auth" class="login-form">
        <input type="hidden" name="next" value={next} />
        <label class="login-label" for="password">Contraseña</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          autofocus
          class="login-input"
        />
        <button type="submit" class="login-submit">Entrar</button>
      </form>
    </main>
  </body>
</html>
