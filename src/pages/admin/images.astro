---
import AdminLayout from "../../components/admin/AdminLayout.astro";
import { readManifest } from "../../lib/admin/manifest";

const manifest = await readManifest();
const allTags = [...new Set(manifest.images.flatMap((i) => i.tags))].sort();
---
<AdminLayout title="Image Library" active="images">
  <div class="lib-toolbar">
    <div class="lib-toolbar-left">
      <div class="lib-search">
        <input
          type="search"
          id="lib-search-input"
          placeholder="Buscar por nombre, alt, tag…"
          class="lib-search-input"
        />
      </div>
      <button class="btn btn-primary" id="lib-upload-btn">+ Subir imágenes</button>
      <input type="file" id="lib-upload-input" multiple accept="image/jpeg,image/png,image/webp,image/heic,image/heif,.heic,.heif" hidden />
      <p class="lib-pick-hint">o arrastra y suelta aquí · recomendado máx 20 por lote</p>
    </div>

    <div class="lib-toolbar-right">
      <span class="lib-count" id="lib-count"></span>
      <button class="btn btn-ghost" id="lib-clear-filters" hidden>Limpiar filtros</button>
    </div>
  </div>

  <div class="lib-layout">
    <aside class="lib-filters">
      <div class="lib-filter-group">
        <div class="lib-filter-title">Sección</div>
        <label class="lib-filter-row">
          <input type="checkbox" data-filter="section" data-value="carousel" />
          <span>En carousel</span>
          <span class="lib-filter-count" id="count-carousel">0</span>
        </label>
        <label class="lib-filter-row">
          <input type="checkbox" data-filter="section" data-value="gallery" />
          <span>En galería</span>
          <span class="lib-filter-count" id="count-gallery">0</span>
        </label>
        <label class="lib-filter-row">
          <input type="checkbox" data-filter="section" data-value="pressOn" />
          <span>En press-on</span>
          <span class="lib-filter-count" id="count-pressOn">0</span>
        </label>
        <label class="lib-filter-row">
          <input type="checkbox" data-filter="section" data-value="unused" />
          <span>Sin usar</span>
          <span class="lib-filter-count" id="count-unused">0</span>
        </label>
      </div>

      <div class="lib-filter-group">
        <div class="lib-filter-title">Visibilidad</div>
        <label class="lib-filter-row">
          <input type="checkbox" data-filter="hidden" data-value="true" />
          <span>Solo ocultas</span>
        </label>
        <label class="lib-filter-row">
          <input type="checkbox" data-filter="hidden" data-value="false" />
          <span>Solo visibles</span>
        </label>
      </div>

      {allTags.length > 0 && (
        <div class="lib-filter-group">
          <div class="lib-filter-title">Tags</div>
          <div class="lib-tag-cloud">
            {allTags.map((t) => (
              <button class="lib-tag-chip" data-filter="tag" data-value={t}>{t}</button>
            ))}
          </div>
        </div>
      )}
    </aside>

    <div class="lib-main">
      <div class="lib-progress" id="lib-progress" hidden>
        <span class="lib-progress-text" id="lib-progress-text"></span>
        <div class="lib-progress-bar"><div class="lib-progress-fill" id="lib-progress-fill"></div></div>
        <ul class="lib-result-list" id="lib-result-list"></ul>
      </div>

      <div class="lib-bulk-bar" id="lib-bulk-bar" hidden>
        <span><span id="lib-bulk-count">0</span> seleccionadas</span>
        <button class="btn" data-bulk="show">Mostrar</button>
        <button class="btn" data-bulk="hide">Ocultar</button>
        <button class="btn" data-bulk="add-carousel">+ Carousel</button>
        <button class="btn" data-bulk="add-gallery">+ Galería</button>
        <button class="btn" data-bulk="remove-all">Quitar de todas</button>
        <button class="btn" data-bulk="delete" data-variant="danger">Eliminar</button>
        <button class="btn btn-ghost" data-bulk="clear" style="margin-left:auto">Limpiar</button>
      </div>

      <div class="lib-grid-wrap">
        <div class="lib-grid" id="lib-grid">
          <div class="lib-empty">Cargando…</div>
        </div>
        <div class="lib-dropzone" id="lib-dropzone">
          <div class="lib-dropzone-inner">
            <div class="lib-dropzone-icon">⤓</div>
            <div class="lib-dropzone-text">Suelta las imágenes para subirlas</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <aside class="lib-detail-panel" id="lib-detail-panel" hidden>
    <button class="lib-detail-close" data-detail-close>×</button>
    <div id="lib-detail-content"></div>
  </aside>

  <template id="lib-image-card-tpl">
    <div class="lib-card" data-id="">
      <div class="lib-card-thumb">
        <img loading="lazy" decoding="async" />
        <div class="lib-card-badges"></div>
        <div class="lib-card-select"><input type="checkbox" /></div>
      </div>
      <div class="lib-card-body">
        <div class="lib-card-name"></div>
        <div class="lib-card-meta"></div>
        <div class="lib-card-tags"></div>
      </div>
    </div>
  </template>

  <template id="lib-result-row-tpl">
    <li class="lib-result" data-status="">
      <span class="lib-result-icon"></span>
      <span class="lib-result-name"></span>
      <span class="lib-result-reason"></span>
    </li>
  </template>

  <script define:vars={{ allTags, allImages: manifest.images.map((i) => ({
    id: i.id, filename: i.filename, alt: i.alt, caption: i.caption, tags: i.tags,
    hidden: i.hidden,
    usedIn: i.usedIn,
    width: i.width, height: i.height,
    variants: i.variants,
  })) }}>
    window.__LIB_INITIAL__ = { allImages };
    window.__LIB_TAGS__ = allTags;
  </script>

  <script>
    // @ts-nocheck
    import Sortable from 'sortablejs';

    const state = {
      images: window.__LIB_INITIAL__?.allImages || [],
      selected: new Set(),
      filters: { q: '', sections: new Set(), tags: new Set(), hidden: null },
    };

    function fmtBytes(n) {
      if (n < 1024) return n + ' B';
      if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
      return (n / 1024 / 1024).toFixed(1) + ' MB';
    }

    function bestThumb(image) {
      if (!image.variants || image.variants.length === 0) return '';
      const w400 = image.variants.find(v => v.width === 400);
      if (w400) return `/optimized/${image.id}/${w400.width}.${w400.format}`;
      const smallest = image.variants.reduce((a, b) => a.width < b.width ? a : b);
      return `/optimized/${image.id}/${smallest.width}.${smallest.format}`;
    }

    function matchesFilters(img) {
      if (state.filters.q) {
        const q = state.filters.q.toLowerCase();
        const hay = [img.filename, img.alt, img.caption, ...img.tags].join(' ').toLowerCase();
        if (!hay.includes(q)) return false;
      }
      if (state.filters.sections.size > 0) {
        const inCarousel = img.usedIn.carousel;
        const inGallery = img.usedIn.gallery;
        const inPressOn = img.usedIn.pressOnPackages.length > 0;
        const unused = !inCarousel && !inGallery && !inPressOn;
        const want = new Set();
        for (const s of state.filters.sections) want.add(s);
        if (want.has('carousel') && !inCarousel) return false;
        if (want.has('gallery') && !inGallery) return false;
        if (want.has('pressOn') && !inPressOn) return false;
        if (want.has('unused') && !unused) return false;
      }
      if (state.filters.hidden !== null) {
        if (state.filters.hidden && !img.hidden) return false;
        if (!state.filters.hidden && img.hidden) return false;
      }
      for (const t of state.filters.tags) {
        if (!img.tags.includes(t)) return false;
      }
      return true;
    }

    function render() {
      const grid = document.getElementById('lib-grid');
      const filtered = state.images.filter(matchesFilters);
      document.getElementById('lib-count').textContent = `${filtered.length} de ${state.images.length}`;
      document.getElementById('lib-clear-filters').hidden = !(
        state.filters.q || state.filters.sections.size || state.filters.tags.size || state.filters.hidden !== null
      );

      if (filtered.length === 0) {
        grid.innerHTML = '<div class="lib-empty">Sin resultados. Ajusta los filtros o sube nuevas imágenes.</div>';
        return;
      }

      const tpl = document.getElementById('lib-image-card-tpl');
      grid.innerHTML = '';
      for (const img of filtered) {
        const node = tpl.content.firstElementChild.cloneNode(true);
        node.dataset.id = img.id;
        if (state.selected.has(img.id)) node.classList.add('is-selected');
        const thumb = node.querySelector('img');
        thumb.src = bestThumb(img);
        thumb.alt = img.alt || img.filename;
        const badges = node.querySelector('.lib-card-badges');
        if (img.usedIn.carousel) badges.innerHTML += '<span class="badge badge-carousel">Carousel</span>';
        if (img.usedIn.gallery) badges.innerHTML += '<span class="badge badge-gallery">Gallery</span>';
        if (img.usedIn.pressOnPackages.length) badges.innerHTML += `<span class="badge badge-presson">Press-On (${img.usedIn.pressOnPackages.length})</span>`;
        if (img.hidden) badges.innerHTML += '<span class="badge badge-hidden">Oculta</span>';
        const checkbox = node.querySelector('input[type=checkbox]');
        checkbox.checked = state.selected.has(img.id);
        checkbox.addEventListener('click', (e) => {
          e.stopPropagation();
          if (checkbox.checked) state.selected.add(img.id);
          else state.selected.delete(img.id);
          updateBulkBar();
          node.classList.toggle('is-selected', checkbox.checked);
        });
        node.querySelector('.lib-card-name').textContent = img.filename;
        node.querySelector('.lib-card-meta').textContent = `${img.width}×${img.height}`;
        const tagsEl = node.querySelector('.lib-card-tags');
        if (img.tags.length === 0) {
          tagsEl.innerHTML = '<span class="lib-card-tag-empty">sin tags</span>';
        } else {
          tagsEl.innerHTML = img.tags.slice(0, 4).map(t => `<span class="lib-card-tag">${escapeHtml(t)}</span>`).join('') + (img.tags.length > 4 ? `<span class="lib-card-tag">+${img.tags.length - 4}</span>` : '');
        }
        node.addEventListener('click', (e) => {
          if (e.target.closest('.lib-card-select')) return;
          openDetail(img.id);
        });
        grid.appendChild(node);
      }
    }

    function escapeHtml(s) {
      const div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    function updateBulkBar() {
      const bar = document.getElementById('lib-bulk-bar');
      const n = state.selected.size;
      bar.hidden = n === 0;
      document.getElementById('lib-bulk-count').textContent = String(n);
    }

    function openDetail(id) {
      const img = state.images.find(i => i.id === id);
      if (!img) return;
      const panel = document.getElementById('lib-detail-panel');
      const content = document.getElementById('lib-detail-content');
      content.innerHTML = `
        <div class="lib-detail-thumb"><img src="${bestThumb(img).replace(/\/400\./, '/800.')}" alt="${escapeHtml(img.alt)}" /></div>
        <div class="lib-detail-section">
          <label class="lib-detail-label" for="detail-filename">Filename</label>
          <input id="detail-filename" type="text" value="${escapeHtml(img.filename)}" />
          <p class="lib-detail-hint">Edit the base name. The extension is kept automatically.</p>
        </div>
        <div class="lib-detail-section">
          <label class="lib-detail-label" for="detail-alt">Alt <span class="lib-detail-required">requerido</span></label>
          <input id="detail-alt" type="text" value="${escapeHtml(img.alt)}" />
        </div>
        <div class="lib-detail-section">
          <label class="lib-detail-label" for="detail-caption">Caption</label>
          <textarea id="detail-caption" rows="2">${escapeHtml(img.caption)}</textarea>
        </div>
        <div class="lib-detail-section">
          <label class="lib-detail-label" for="detail-tags">Tags (separados por coma)</label>
          <input id="detail-tags" type="text" value="${escapeHtml(img.tags.join(', '))}" />
        </div>
        <div class="lib-detail-section">
          <div class="lib-detail-label">Visible en</div>
          <label class="lib-detail-check"><input type="checkbox" id="detail-carousel" ${img.usedIn.carousel ? 'checked' : ''} /> Carrusel del home</label>
          <label class="lib-detail-check"><input type="checkbox" id="detail-gallery" ${img.usedIn.gallery ? 'checked' : ''} /> Galería pública</label>
          ${img.usedIn.pressOnPackages.length ? `<div class="lib-detail-static">Press-On: ${img.usedIn.pressOnPackages.length} paquete(s)</div>` : ''}
        </div>
        <div class="lib-detail-section">
          <label class="lib-detail-check"><input type="checkbox" id="detail-hidden" ${img.hidden ? 'checked' : ''} /> Oculta (no se renderiza en ningún lado)</label>
        </div>
        <div class="lib-detail-section lib-detail-meta">
          <div>${img.width}×${img.height} · ${fmtBytes(state.images.find(i=>i.id===id)?.variants.reduce((s,v)=>s+v.size,0) || 0)} en variantes</div>
          <div>ID: <code>${img.id}</code></div>
        </div>
        <div class="lib-detail-actions">
          <button class="btn btn-primary" id="detail-save">Guardar</button>
          <button class="btn btn-danger" id="detail-delete">Eliminar imagen</button>
        </div>
      `;
      panel.hidden = false;
      panel.classList.add('is-open');

      document.getElementById('detail-save').addEventListener('click', async () => {
        const patch = {
          alt: document.getElementById('detail-alt').value,
          caption: document.getElementById('detail-caption').value,
          tags: document.getElementById('detail-tags').value.split(',').map(s => s.trim()).filter(Boolean),
          hidden: document.getElementById('detail-hidden').checked,
          filename: document.getElementById('detail-filename').value,
          usedIn: {
            carousel: document.getElementById('detail-carousel').checked,
            gallery: document.getElementById('detail-gallery').checked,
          },
        };
        const r = await fetch(`/api/admin/images/${img.id}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(patch),
        });
        if (r.ok) {
          const data = await r.json();
          Object.assign(img, data.image);
          window.adminToast('Guardado', 'success');
          render();
          updateFilterCounts();
        } else {
          window.adminToast('Error al guardar', 'error');
        }
      });

      document.getElementById('detail-delete').addEventListener('click', async () => {
        if (!confirm(`¿Eliminar "${img.filename}"? Esto borra el archivo original y todas las variantes.`)) return;
        const r = await fetch(`/api/admin/images/${img.id}`, { method: 'DELETE' });
        if (r.ok) {
          state.images = state.images.filter(i => i.id !== img.id);
          state.selected.delete(img.id);
          panel.hidden = true;
          panel.classList.remove('is-open');
          window.adminToast('Eliminada', 'success');
          render();
          updateFilterCounts();
        } else {
          window.adminToast('Error al eliminar', 'error');
        }
      });
    }

    document.querySelector('[data-detail-close]')?.addEventListener('click', () => {
      document.getElementById('lib-detail-panel').hidden = true;
      document.getElementById('lib-detail-panel').classList.remove('is-open');
    });

    function updateFilterCounts() {
      const carousel = state.images.filter(i => i.usedIn.carousel).length;
      const gallery = state.images.filter(i => i.usedIn.gallery).length;
      const pressOn = state.images.filter(i => i.usedIn.pressOnPackages.length > 0).length;
      const unused = state.images.filter(i => !i.usedIn.carousel && !i.usedIn.gallery && i.usedIn.pressOnPackages.length === 0).length;
      document.getElementById('count-carousel').textContent = String(carousel);
      document.getElementById('count-gallery').textContent = String(gallery);
      document.getElementById('count-pressOn').textContent = String(pressOn);
      document.getElementById('count-unused').textContent = String(unused);
    }

    document.getElementById('lib-search-input').addEventListener('input', (e) => {
      state.filters.q = e.target.value;
      render();
    });

    document.querySelectorAll('[data-filter="section"]').forEach(cb => {
      cb.addEventListener('change', (e) => {
        const v = e.target.dataset.value;
        if (e.target.checked) state.filters.sections.add(v);
        else state.filters.sections.delete(v);
        render();
      });
    });

    document.querySelectorAll('[data-filter="hidden"]').forEach(cb => {
      cb.addEventListener('change', (e) => {
        document.querySelectorAll('[data-filter="hidden"]').forEach(o => { if (o !== e.target) o.checked = false; });
        state.filters.hidden = e.target.checked ? e.target.dataset.value === 'true' : null;
        render();
      });
    });

    document.querySelectorAll('[data-filter="tag"]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const v = btn.dataset.value;
        if (state.filters.tags.has(v)) {
          state.filters.tags.delete(v);
          btn.classList.remove('is-active');
        } else {
          state.filters.tags.add(v);
          btn.classList.add('is-active');
        }
        render();
      });
    });

    document.getElementById('lib-clear-filters').addEventListener('click', () => {
      state.filters = { q: '', sections: new Set(), tags: new Set(), hidden: null };
      document.getElementById('lib-search-input').value = '';
      document.querySelectorAll('[data-filter="section"],[data-filter="hidden"]').forEach(o => o.checked = false);
      document.querySelectorAll('[data-filter="tag"]').forEach(o => o.classList.remove('is-active'));
      render();
    });

    const SOFT_CAP = 20;
    const progressEl = document.getElementById('lib-progress');
    const progressText = document.getElementById('lib-progress-text');
    const progressFill = document.getElementById('lib-progress-fill');
    const resultList = document.getElementById('lib-result-list');
    const dropzone = document.getElementById('lib-dropzone');
    const resultTpl = document.getElementById('lib-result-row-tpl');

    async function uploadFiles(files) {
      const arr = Array.from(files || []);
      if (arr.length === 0) return;
      if (arr.length > SOFT_CAP && !confirm(`Vas a subir ${arr.length} imágenes. ¿Continuar?`)) return;

      progressEl.hidden = false;
      resultList.innerHTML = '';
      progressText.textContent = `Subiendo 0/${arr.length}…`;
      progressFill.style.width = '0%';

      const fd = new FormData();
      for (const f of arr) fd.append('files', f);

      let data;
      try {
        const r = await fetch('/api/admin/images', { method: 'POST', body: fd });
        data = await r.json();
      } catch (err) {
        window.adminToast('Error al subir', 'error');
        progressEl.hidden = true;
        return;
      }

      let done = 0;
      for (const res of (data.results || [])) {
        done++;
        const node = resultTpl.content.firstElementChild.cloneNode(true);
        node.dataset.status = res.ok ? 'ok' : 'fail';
        node.querySelector('.lib-result-icon').textContent = res.ok ? '✓' : '✗';
        node.querySelector('.lib-result-name').textContent = res.image?.filename || res.error || 'archivo';
        if (!res.ok && res.error) node.querySelector('.lib-result-reason').textContent = res.error;
        resultList.appendChild(node);
        progressText.textContent = `Subiendo ${done}/${arr.length}…`;
        progressFill.style.width = `${(done / arr.length) * 100}%`;
      }

      window.adminToast(
        `${data.uploaded || 0} subida(s)${data.failed ? `, ${data.failed} fallida(s)` : ''}`,
        data.failed ? 'info' : 'success'
      );

      try {
        const list = await (await fetch('/api/admin/images')).json();
        state.images = list.images;
      } catch {}

      render();
      updateFilterCounts();

      setTimeout(() => { progressEl.hidden = true; }, 6000);
    }

    document.getElementById('lib-upload-btn').addEventListener('click', () => {
      document.getElementById('lib-upload-input').click();
    });

    document.getElementById('lib-upload-input').addEventListener('change', async (e) => {
      await uploadFiles(e.target.files);
      e.target.value = '';
    });

    let dragCounter = 0;
    const gridWrap = document.querySelector('.lib-grid-wrap');
    gridWrap?.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dragCounter++;
      dropzone.classList.add('is-active');
    });
    gridWrap?.addEventListener('dragover', (e) => {
      e.preventDefault();
    });
    gridWrap?.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dragCounter = Math.max(0, dragCounter - 1);
      if (dragCounter === 0) dropzone.classList.remove('is-active');
    });
    gridWrap?.addEventListener('drop', async (e) => {
      e.preventDefault();
      dragCounter = 0;
      dropzone.classList.remove('is-active');
      await uploadFiles(e.dataTransfer?.files);
    });
    document.addEventListener('dragover', (e) => e.preventDefault());
    document.addEventListener('drop', (e) => e.preventDefault());

    document.querySelectorAll('[data-bulk]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.bulk;
        const ids = [...state.selected];
        if (action === 'clear') {
          state.selected.clear();
          updateBulkBar();
          render();
          return;
        }
        if (ids.length === 0) return;

        if (action === 'delete') {
          if (!confirm(`¿Eliminar ${ids.length} imagen(es)? Esta acción no se puede deshacer.`)) return;
          for (const id of ids) {
            await fetch(`/api/admin/images/${id}`, { method: 'DELETE' });
          }
          state.images = state.images.filter(i => !ids.includes(i.id));
          state.selected.clear();
          window.adminToast(`${ids.length} eliminada(s)`, 'success');
        } else {
          const patch: any = {};
          if (action === 'show') patch.hidden = false;
          else if (action === 'hide') patch.hidden = true;
          else if (action === 'add-carousel') patch.usedIn = { carousel: true };
          else if (action === 'add-gallery') patch.usedIn = { gallery: true };
          else if (action === 'remove-all') patch.usedIn = { carousel: false, gallery: false };

          const r = await fetch('/api/admin/images/bulk', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ ids, patch }),
          });
          if (r.ok) {
            const list = await (await fetch('/api/admin/images')).json();
            state.images = list.images;
            window.adminToast('Actualizado', 'success');
          }
        }
        updateBulkBar();
        render();
        updateFilterCounts();
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const panel = document.getElementById('lib-detail-panel');
        if (!panel.hidden) {
          panel.hidden = true;
          panel.classList.remove('is-open');
        }
      }
    });

    updateFilterCounts();
    render();
  </script>
</AdminLayout>
