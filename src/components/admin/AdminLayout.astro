---
import "../../styles/admin.css";
import { newCsrfToken, getCsrfFromCookieHeader, buildCsrfCookie } from "../../lib/admin/auth";

interface Props {
  title: string;
  active: "dashboard" | "images" | "carousel" | "gallery" | "press-on";
}

const { title, active } = Astro.props;

const existingCsrf = getCsrfFromCookieHeader(Astro.request.headers.get("cookie") ?? "");
const csrf = existingCsrf ?? newCsrfToken();
if (!existingCsrf) {
  Astro.response.headers.append("Set-Cookie", buildCsrfCookie(csrf));
}

const navItems = [
  { id: "dashboard", label: "Dashboard", href: "/admin", icon: "•" },
  { id: "images", label: "Images", href: "/admin/images", icon: "🖼" },
  { id: "carousel", label: "Carousel", href: "/admin/carousel", icon: "🎠" },
  { id: "gallery", label: "Gallery", href: "/admin/gallery", icon: "🪞" },
  { id: "press-on", label: "Press-On", href: "/admin/press-on", icon: "💅" },
] as const;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} · Admin</title>
  </head>
  <body class="admin-body">
    <aside class="admin-sidebar">
      <div class="admin-brand">
        <div class="admin-brand-mark">BF</div>
        <div class="admin-brand-text">
          <div class="admin-brand-name">Bare Form</div>
          <div class="admin-brand-sub">Admin</div>
        </div>
      </div>

      <nav class="admin-nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`admin-nav-link ${active === item.id ? "is-active" : ""}`}
            data-nav={item.id}
          >
            <span class="admin-nav-icon">{item.icon}</span>
            <span class="admin-nav-label">{item.label}</span>
          </a>
        ))}
      </nav>

      <div class="admin-sidebar-foot">
        <a href="/" class="admin-foot-link" target="_blank">↗ Ver sitio</a>
        <form method="POST" action="/api/admin/auth" class="logout-form">
          <input type="hidden" name="_method" value="DELETE" />
          <button type="button" class="logout-btn" data-action="logout">Cerrar sesión</button>
        </form>
      </div>
    </aside>

    <main class="admin-main">
      <header class="admin-topbar">
        <button class="admin-burger" data-burger aria-label="Abrir menú">☰</button>
        <h1 class="admin-page-title">{title}</h1>
        <div class="admin-topbar-right">
          <slot name="topbar-right" />
        </div>
      </header>

      <div class="admin-content">
        <slot />
      </div>
    </main>

    <button class="admin-nav-scrim" data-burger-scrim aria-label="Cerrar menú"></button>

    <div id="toast-host" class="toast-host" aria-live="polite"></div>

    <meta name="csrf" content={csrf} />

    <script>
      // @ts-nocheck
      const csrf = document.querySelector('meta[name="csrf"]')?.getAttribute("content") || "";
      window.__CSRF__ = csrf;

      document.querySelector('[data-action="logout"]')?.addEventListener("click", async () => {
        await fetch("/api/admin/auth", { method: "DELETE" });
        window.location.href = "/admin/login";
      });

      window.adminToast = function (msg, type = "info") {
        const host = document.getElementById("toast-host");
        if (!host) return;
        const t = document.createElement("div");
        t.className = "toast toast-" + type;
        t.textContent = msg;
        host.appendChild(t);
        setTimeout(() => { t.classList.add("toast-out"); }, 2400);
        setTimeout(() => { t.remove(); }, 2900);
      };

      const origFetch = window.fetch;
      window.fetch = async function (input, init) {
        init = init || {};
        const method = (init.method || "GET").toUpperCase();
        if (method !== "GET" && method !== "HEAD") {
          init.headers = { ...(init.headers || {}), "X-CSRF-Token": csrf };
        }
        return origFetch(input, init);
      };

      const burger = document.querySelector('[data-burger]');
      const scrim = document.querySelector('[data-burger-scrim]');
      const setNav = (open) => {
        document.body.classList.toggle('nav-open', open);
      };
      burger?.addEventListener('click', () => setNav(!document.body.classList.contains('nav-open')));
      scrim?.addEventListener('click', () => setNav(false));
      document.querySelectorAll('.admin-nav-link').forEach((a) => a.addEventListener('click', () => setNav(false)));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setNav(false); });
    </script>
  </body>
</html>
