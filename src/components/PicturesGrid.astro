---
import PictureCard from "./PictureCard.astro";
import "../styles/components/pictures-grid.css";
import { getManifestBySection } from "../server/lib/storage";
import fs from "node:fs";
import { uploadPath } from "../server/lib/storage";

let images: Array<{ url: string; alt: string; id: string }> = [];
try {
  const raw = await getManifestBySection("gallery");
  images = raw
    .map((m) => {
      const full = uploadPath(m.filename);
      if (!fs.existsSync(full)) return null;
      return { url: `/api/uploads/${m.filename}`, alt: m.alt, id: m.id };
    })
    .filter((x): x is NonNullable<typeof x> => x != null);
} catch (err) {
  console.error("PicturesGrid: failed to read manifest", err);
}
---

<div class="gallery-wrapper">
  {images.length === 0 ? (
    <div class="empty-state" style="text-align:center;padding:60px 20px;color:#888">
      <p>No hay fotos en la galería todavía.</p>
    </div>
  ) : (
    <div class="pictures-grid">
      {images.map((image) => (
        <PictureCard src={image.url} alt={image.alt} />
      ))}
    </div>
  )}
</div>