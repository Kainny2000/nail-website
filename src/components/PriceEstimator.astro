---
import { services, categories } from "../data/services";
import "../styles/components/price-estimator.css";
---

<div class="price-estimator" id="price-estimator">
    <div class="estimator-container">
        <div class="categories-section">
            {
                categories.map((category) => (
                    <div class="category-group" data-category={category.id}>
                        <h2 class="category-title">{category.name}</h2>
                        <p class="category-desc">{category.description}</p>
                        <div class="services-list">
                            {services
                                .filter((s) => s.category === category.id)
                                .map((service) => (
                                    <div
                                        class={`service-item ${service.isAddon ? "addon-item" : "base-item"}`}
                                        data-id={service.id}
                                        data-price={service.price}
                                        data-category={service.category}
                                        data-addon={
                                            service.isAddon ? "true" : "false"
                                        }
                                    >
                                        <div class="service-info">
                                            <img
                                                src={service.icon}
                                                alt=""
                                                class="service-icon"
                                            />
                                            <div class="service-details">
                                                <span class="service-name">
                                                    {service.name}
                                                </span>
                                                <span class="service-description">
                                                    {service.description}
                                                </span>
                                            </div>
                                        </div>
                                        <div class="service-action">
                                            <span class="service-price">
                                                ${service.price}{service.category === 'nails' ? '+' : ''}
                                            </span>
                                            <button
                                                class="select-btn"
                                                aria-label={`Seleccionar ${service.name}`}
                                            >
                                                <span class="btn-icon">+</span>
                                            </button>
                                        </div>
                                    </div>
                                ))}
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="summary-section">
            <div class="summary-card">
                <h3 class="summary-title">Tu Selección</h3>
                <div id="selected-services" class="selected-services">
                    <p class="empty-msg">
                        No has seleccionado ningún servicio aún.
                    </p>
                </div>
                <div class="summary-footer">
                    <div class="total-row">
                        <span>Total Estimado</span>
                        <span id="total-price" class="total-amount">$0</span>
                    </div>
                    <button class="book-btn" id="book-btn" disabled style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        Reservar Ahora
                    </button>
                    <p class="design-price-note" style="font-size: 0.75rem; color: var(--color-text-light, #666); text-align: center; margin-top: 12px; font-style: italic;">
                        + el precio varía deacorde a la complejidad del diseño
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const estimator = document.getElementById("price-estimator");
    const serviceItems =
        document.querySelectorAll<HTMLElement>(".service-item");
    const selectedList = document.getElementById("selected-services");
    const totalPriceEl = document.getElementById("total-price");
    const bookBtn = document.getElementById(
        "book-btn",
    ) as HTMLButtonElement | null;

    let selectedServices = new Map();

    function updateUI() {
        if (!selectedList || !bookBtn || !totalPriceEl) return;

        // Update selected list
        if (selectedServices.size === 0) {
            selectedList.innerHTML =
                '<p class="empty-msg">No has seleccionado ningún servicio aún.</p>';
            bookBtn.disabled = true;
        } else {
            selectedList.innerHTML = "";
            let total = 0;
            let hasNails = false;
            selectedServices.forEach((service, id) => {
                if (service.category === 'nails') hasNails = true;
                const item = document.createElement("div");
                item.className = "selected-item";
                item.innerHTML = `
          <span>${service.name}</span>
          <span>$${service.price}${service.category === 'nails' ? '+' : ''}</span>
        `;
                selectedList.appendChild(item);
                total += service.price;
            });
            totalPriceEl.textContent = `$${total}${hasNails ? '+' : ''}`;
            bookBtn.disabled = false;
        }

        // Update item states
        serviceItems.forEach((item) => {
            const id = item.dataset.id;
            if (id && selectedServices.has(id)) {
                item.classList.add("selected");
            } else {
                item.classList.remove("selected");
            }
        });
    }

    serviceItems.forEach((item) => {
        item.addEventListener("click", () => {
            const id = item.dataset.id;
            const nameEl = item.querySelector(".service-name");
            const priceStr = item.dataset.price;
            const category = item.dataset.category;

            if (!id || !nameEl || !priceStr) return;

            const name = nameEl.textContent || "";
            const price = parseInt(priceStr);

            if (selectedServices.has(id)) {
                selectedServices.delete(id);
            } else {
                selectedServices.set(id, { name, price, category });
            }
            updateUI();
        });
    });

    if (bookBtn) {
        bookBtn.addEventListener("click", () => {
            if (!bookBtn.disabled) {
                let message = "Hola, me gustaría reservar una cita. Mis servicios seleccionados son:\n\n";
                let hasNails = false;
                selectedServices.forEach((service) => {
                    if (service.category === 'nails') hasNails = true;
                    message += `- ${service.name}: $${service.price}${service.category === 'nails' ? '+' : ''}\n`;
                });
                const total = Array.from(selectedServices.values()).reduce((sum, s) => sum + s.price, 0);
                message += `\nTotal estimado: $${total}${hasNails ? '+' : ''}`;
                
                const encodedMessage = encodeURIComponent(message);
                window.open(
                    `https://wa.me/3852410496?text=${encodedMessage}`,
                    "_blank",
                );
            }
        });
    }
</script>
