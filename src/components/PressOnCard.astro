---
import "../styles/components/press-on-card.css";

interface Props {
  name: string;
  description: string;
  price: string;
  imageUrl: string;
}

const { name, description, price, imageUrl } = Astro.props;
---

<div class="press-on-card">
  <div class="press-on-card-image">
    {imageUrl ? (
      <img src={imageUrl} alt={name} class="press-on-card-img" loading="lazy" decoding="async" />
    ) : (
      <>
        <div class="press-on-card-placeholder">Diseno</div>
        <div class="press-on-card-sample">Muestra</div>
      </>
    )}
  </div>
  <div class="press-on-card-body">
    <h2 class="press-on-card-title">{name}</h2>
    {description && <p class="press-on-card-desc">{description}</p>}
    {price && <p class="press-on-card-price">{price}</p>}
  </div>
</div>