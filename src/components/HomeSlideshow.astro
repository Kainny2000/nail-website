---
import "../styles/components/home-slideshow.css";
import { getManifestBySection, uploadPath, type ManifestItem } from "../server/lib/storage";
import fs from "node:fs";

let manifest: (ManifestItem & { url: string })[] = [];
try {
  const raw = await getManifestBySection("slideshow");
  manifest = raw
    .map((m) => {
      const full = uploadPath(m.filename);
      if (!fs.existsSync(full)) return null;
      return { ...m, url: `/api/uploads/${m.filename}` };
    })
    .filter((x): x is NonNullable<typeof x> => x != null);
} catch (err) {
  console.error("HomeSlideshow: failed to read manifest", err);
}

const items = manifest;
---

<div class="home-slideshow">
    <div class="slides-container">
        {
            items.length === 0 ? (
                <div class="slide active" data-index="0">
                    <div class="slide-empty">Próximamente nuevas fotos</div>
                </div>
            ) : (
                items.map((item, index) => (
                    <div
                        class={`slide ${index === 0 ? "active" : ""}`}
                        data-index={index}
                    >
                        <img
                            src={item.url}
                            alt={item.alt}
                            width="1200"
                            height="800"
                            class="slide-image"
                            loading={index === 0 ? "eager" : "lazy"}
                            decoding="async"
                        />
                    </div>
                ))
            )
        }
    </div>
    <div class="slideshow-overlay">
        <div class="overlay-content">
            <h1 class="hero-title">Coco Nails</h1>
            <p class="hero-subtitle">Manicurista independiente</p>
        </div>
    </div>
</div>

<script>
    const slides = document.querySelectorAll(".slide");
    let currentSlide = 0;

    function nextSlide() {
        if (slides.length === 0) return;
        slides[currentSlide].classList.remove("active");
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add("active");
    }

    if (slides.length > 1) {
        setInterval(nextSlide, 5000);
    }
</script>
