---
import type {Service} from '../data/services';

export interface Props extends Service {}

const { name, description, price, icon } = Astro.props;
---

<div class="service-card">
  <h1>{name}</h1>
  <p>{description}</p>
  <p>Precio desde: ${price}</p>
  <img class=icon src={`${icon}`} alt={`${name} icon`} />

</div>




